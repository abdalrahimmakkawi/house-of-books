# Cache control for index.html to prevent Cloudflare caching
/index.html
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0

# Cache control for HTML files
/*.html
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0

# Cache control for assets with versioning (can be cached longer)
/assets/*
  Cache-Control: public, max-age=31536000, immutable
